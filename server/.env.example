# === DATABASE ===
# Railway provides this automatically when you add a PostgreSQL plugin
DATABASE_URL="postgresql://postgres:password123@localhost:5432/unolo_db"

# === AUTH ===
JWT_SECRET="supersecretjwtkey_change_this_in_production"

# === SERVER ===
PORT=5000
NODE_ENV="development"

# === CORS ===
# Set this to your Vercel frontend URL in production (e.g. https://unolo-clone.vercel.app)
CLIENT_URL="http://localhost:5173"

# === EMAIL (Optional) ===
# Leave blank to use Ethereal test emails. For real emails, fill these in:
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=465
# SMTP_SECURE="true"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-password"
